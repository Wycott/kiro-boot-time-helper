<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>UptimeTracker</RootNamespace>
    <AssemblyName>UptimeTracker.Tui</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\UptimeTracker.Library\UptimeTracker.Library.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="uptime-tracker.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
